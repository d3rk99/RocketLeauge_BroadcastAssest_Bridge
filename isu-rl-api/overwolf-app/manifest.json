{
  "manifest_version": 1,
  "type": "WebApp",
  "meta": {
    "name": "ISU RL API",
    "author": "ISU RL API",
    "version": "0.1.0",
    "minimum-overwolf-version": "0.240.0",
    "description": "Rocket League event bridge for broadcast overlays",
	"icon": "public/icon.png"
  },
  "data": {
    "start_window": "background",
    "game_targeting": {
      "type": "dedicated",
      "game_ids": [10826]
    }
  },
  "permissions": ["GameInfo", "Web"],
  "windows": {
    "background": {
      "file": "public/background.html",
      "is_background_page": true
    },
    "debug": {
      "file": "public/debug.html"
    }
  }
}
